{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} | {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "FrontendUrl": "http://localhost:3000",
  "Jwt": {
    "Key": "",
    "Issuer": "archlens-auth",
    "Audience": "archlens-services"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "upload-route": {
        "ClusterId": "upload-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/upload/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/upload" }
        ]
      },
      "orchestrator-route": {
        "ClusterId": "orchestrator-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/orchestrator/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/orchestrator" }
        ]
      },
      "report-route": {
        "ClusterId": "report-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/reports/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/reports" }
        ]
      },
      "ai-route": {
        "ClusterId": "ai-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/ai/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/ai" }
        ]
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/hubs/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "http://localhost:5120"
          }
        }
      },
      "upload-cluster": {
        "Destinations": {
          "upload": {
            "Address": "http://localhost:5066"
          }
        }
      },
      "orchestrator-cluster": {
        "Destinations": {
          "orchestrator": {
            "Address": "http://localhost:5089"
          }
        }
      },
      "report-cluster": {
        "Destinations": {
          "report": {
            "Address": "http://localhost:5205"
          }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "ai": {
            "Address": "http://localhost:8000"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification": {
            "Address": "http://localhost:5150"
          }
        }
      }
    }
  }
}
